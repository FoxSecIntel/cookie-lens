{
  "manifest_version": 3,
  "name": "Cookie Lens",
  "version": "1.0.5",
  "description": "Translate technical cookies into plain English privacy explanations.",
  "permissions": ["cookies", "activeTab", "tabs", "clipboardWrite", "downloads", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie Lens"
  }
}
